# Local development bucket configuration
# Copy this file to .env.local and fill in the real values.

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Railway bucket variable aliases also work
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

# Optional for S3-compatible providers like Cloudflare R2 or Railway buckets
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=

# Optional local overrides
PORT=3001
ASSET_URL_SIGN_TTL_SECONDS=900
PUBLIC_SITE_ORIGIN=http://localhost:5173

# Resend email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
